OPENAI_API_KEY=your_openai_api_key_here

# Password protection — required for the auth gate
APP_PASSWORD=your_app_password_here
SESSION_SECRET=a_long_random_secret_string_here
# Optional. Default is 12 hours. Hard cap is 7 days.
RUNE_SESSION_MAX_AGE_SECONDS=43200

# Supabase — required for persistent chat history (optional, app works without it)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Tavily — optional, enables real-time web search
# Get a free API key at https://tavily.com
TAVILY_API_KEY=

# GitHub — optional, increases GitHub API rate limit from 60 to 5000 req/hr
# Create a personal access token at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Sandboxed code execution — enabled by default on the Node.js runtime
# Set to false to disable execution entirely in a deployment
RUNE_CODE_EXECUTION_ENABLED=true

# Optional execution limits for the JS/TS sandbox
# Defaults shown below; all values are clamped to safe ranges at runtime.
RUNE_CODE_TIMEOUT_MS=5000
RUNE_CODE_MAX_SOURCE_LENGTH=10000
RUNE_CODE_MAX_OUTPUT_CHARS=12000
RUNE_CODE_MAX_ARTIFACTS=5
RUNE_CODE_MAX_ARTIFACT_BYTES=24000
RUNE_CODE_MEMORY_LIMIT_MB=64
RUNE_CODE_MAX_WORKER_RETRIES=1

# Optional chat usage controls
# Protects deployments from burst abuse per workspace session.
RUNE_CHAT_MAX_REQUESTS_PER_MINUTE=20

# Optional: override the OpenAI chat model. Defaults to gpt-4o-mini.
# Changing this env var (and redeploying) is all that is needed to switch models.
RUNE_CHAT_MODEL=gpt-4o-mini

# Optional: private owner/project memory injected server-side into Jarvis.
# Keep this in Vercel env vars only; do not commit private memory to GitHub.
RUNE_OWNER_MEMORY=

# Optional: protect POST /api/memory/seed with a private token.
# If unset, the seed endpoint is allowed behind the app password gate.
RUNE_MEMORY_SEED_TOKEN=


# Optional: restrict which image hostnames may be forwarded to the AI vision API.
# Comma-separated list of hostnames. Leave unset to allow any HTTPS URL (dev default).
# Example: RUNE_ALLOWED_IMAGE_HOSTS=your-cdn.example.com,storage.googleapis.com
RUNE_ALLOWED_IMAGE_HOSTS=

# Optional: build intelligence panel
# RUNE_GITHUB_REPO defaults to Tanjiro-1122/Rune. GITHUB_TOKEN or RUNE_GITHUB_TOKEN improves private/rate-limited repo inspection.
RUNE_GITHUB_REPO=Tanjiro-1122/Rune
RUNE_GITHUB_TOKEN=

# Optional: Vercel deployment intelligence. Use a Vercel token with read access to the Jarvis project.
RUNE_VERCEL_TOKEN=
RUNE_VERCEL_PROJECT_ID=
RUNE_VERCEL_PROJECT_NAME=Jarvis
RUNE_VERCEL_TEAM_ID=
